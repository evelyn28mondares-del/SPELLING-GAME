<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Word Match Learning Hub</title>
    <style>
        :root {
            --primary: #4a90e2;
            --success: #2ec4b6;
            --background: #f4f7f6;
            --text: #333;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--background);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .game-container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            width: 90%;
            max-width: 600px;
            text-align: center;
        }

        .section {
            margin: 20px 0;
            transition: all 0.3s ease;
        }

        .hidden {
            display: none !important;
        }

        button {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            margin: 10px;
            transition: transform 0.1s;
        }

        button:hover, button:focus {
            transform: scale(1.05);
            outline: 3px solid #333;
        }

        #dashboard {
            display: flex;
            justify-content: space-around;
            background: #eef2f7;
            padding: 15px;
            border-radius: 8px;
        }

        .player-stats {
            padding: 10px 20px;
            border-radius: 6px;
            width: 40%;
        }

        .active-player {
            background: #d4edda;
            border: 2px solid var(--success);
        }

        .game-columns {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-top: 20px;
        }

        .column {
            flex: 1;
        }

        .draggable, .target {
            padding: 15px;
            margin: 10px 0;
            background: #fff;
            border: 2px dashed #ccc;
            border-radius: 6px;
            cursor: grab;
            font-weight: bold;
            user-select: none;
        }

        .draggable:focus, .target:focus {
            outline: 3px solid var(--primary);
        }

        .target {
            background: #f9f9f9;
            border-style: solid;
        }

        .target.drag-over {
            background: #e3f2fd;
            border-color: var(--primary);
        }

        .matched {
            background-color: #d4edda !important;
            border-color: var(--success) !important;
            color: #155724;
            cursor: default;
        }

        .accessibility-note {
            font-size: 13px;
            color: #666;
            margin-top: 15px;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-6px); }
            40%, 80% { transform: translateX(6px); }
        }
    </style>
</head>
<body>

    <div class="game-container">
        <h1>Word Match Learning Hub</h1>
        
        <div id="mode-selection" class="section">
            <h2>Select Game Mode</h2>
            <button id="btn-single" onclick="setMode('single')">Single Player</button>
            <button id="btn-double" onclick="setMode('double')">Double Player</button>
            <p class="accessibility-note">💡 Accessibility: Use <strong>Tab</strong> to navigate, <strong>Space/Enter</strong> to select, and <strong>1-3 keys</strong> to drop items via keyboard!</p>
        </div>

        <div id="dashboard" class="section hidden">
            <div id="p1-stats" class="player-stats active-player">
                <h3>Player 1</h3>
                <p>Score: <span id="p1-score">0</span></p>
                <p>Time Left: <span id="p1-timer">30</span>s</p>
            </div>
            <div id="p2-stats" class="player-stats hidden">
                <h3>Player 2</h3>
                <p>Score: <span id="p2-score">0</span></p>
                <p>Time Left: <span id="p2-timer">30</span>s</p>
            </div>
        </div>

        <div id="game-board" class="section hidden">
            <div class="game-columns">
                <div class="column">
                    <h3>Words (Drag Me)</h3>
                    <div id="draggable-container"></div>
                </div>
                
                <div class="column">
                    <h3>Matches (Drop Here)</h3>
                    <div id="target-container"></div>
                </div>
            </div>
        </div>

        <div id="game-over" class="section hidden">
            <h2>Game Over!</h2>
            <div id="final-results"></div>
            <button onclick="resetGame()">Play Again</button>
        </div>
    </div>

    <script>
        // Game Configurations & Data
        const gameData = [
            { word: "GIRL", match: "GIRL" },
            { word: "BAG", match: "BAG" },
            { word: "HEN", match: "HEN" }
        ];

        let gameMode = 'single'; 
        let currentPlayer = 1;
        let scores = { player1: 0, player2: 0 };
        let timers = { player1: 30, player2: 30 };
        let timerInterval;
        let activeKeyboardElement = null;

        // DOM Elements
        const modeSelection = document.getElementById('mode-selection');
        const dashboard = document.getElementById('dashboard');
        const gameBoard = document.getElementById('game-board');
        const gameOverScreen = document.getElementById('game-over');
        const draggableContainer = document.getElementById('draggable-container');
        const targetContainer = document.getElementById('target-container');

        function setMode(mode) {
            gameMode = mode;
            modeSelection.classList.add('hidden');
            dashboard.classList.remove('hidden');
            gameBoard.classList.remove('hidden');
            
            if (gameMode === 'double') {
                document.getElementById('p2-stats').classList.remove('hidden');
            }
            
            initializeRound();
        }

        function initializeRound() {
            draggableContainer.innerHTML = '';
            targetContainer.innerHTML = '';
            
            if (currentPlayer === 1) {
                document.getElementById('p1-stats').classList.add('active-player');
                document.getElementById('p2-stats').classList.remove('active-player');
            } else {
                document.getElementById('p2-stats').classList.add('active-player');
                document.getElementById('p1-stats').classList.remove('active-player');
            }

            const shuffledWords = [...gameData].sort(() => Math.random() - 0.5);
            const shuffledTargets = [...gameData].sort(() => Math.random() - 0.5);

            // Create Draggable Elements
            shuffledWords.forEach((item) => {
                const div = document.createElement('div');
                div.className = 'draggable';
                div.textContent = item.word;
                div.draggable = true;
                div.id = `word-${item.word}`;
                div.setAttribute('tabindex', '0'); 
                div.setAttribute('aria-label', `${item.word}. Press space to select.`);
                
                div.addEventListener('dragstart', dragStart);
                div.addEventListener('keydown', (e) => handleKeyboardSelection(e, div));

                draggableContainer.appendChild(div);
            });

            // Create Target Drop Zones
            shuffledTargets.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'target';
                div.innerHTML = `<span style="color: #888; font-size:12px;">[Press ${index + 1}]</span> Match: ${item.match}`;
                div.dataset.match = item.match;
                
                div.addEventListener('dragover', dragOver);
                div.addEventListener('dragleave', dragLeave);
                div.addEventListener('drop', dropElement);

                targetContainer.appendChild(div);
            });

            startTimer();
        }

        // --- Drag & Drop Core ---
        function dragStart(e) {
            e.dataTransfer.setData('text/plain', e.target.id);
        }

        function dragOver(e) {
            e.preventDefault();
            if (!e.target.classList.contains('matched')) {
                e.target.classList.add('drag-over');
            }
        }

        function dragLeave(e) {
            e.target.classList.remove('drag-over');
        }

        function dropElement(e) {
            e.preventDefault();
            e.target.classList.remove('drag-over');
            const draggedId = e.dataTransfer.getData('text/plain');
            const draggedEl = document.getElementById(draggedId);
            
            validateMatch(draggedEl, e.target);
        }

        // --- Keyboard Support Engine ---
        function handleKeyboardSelection(e, element) {
            if (e.key === ' ' || e.key === 'Enter') {
                e.preventDefault();
                if (activeKeyboardElement) activeKeyboardElement.style.borderColor = '#ccc';
                activeKeyboardElement = element;
                element.style.borderColor = 'var(--primary)';
            }
            
            if (activeKeyboardElement && ['1', '2', '3'].includes(e.key)) {
                const targetIdx = parseInt(e.key) - 1;
                const targets = targetContainer.querySelectorAll('.target');
                if(targets[targetIdx]) {
                    validateMatch(activeKeyboardElement, targets[targetIdx]);
                    activeKeyboardElement = null;
                }
            }
        }

        // --- Validation Logic ---
        function validateMatch(sourceEl, targetEl) {
            if (!sourceEl || !targetEl || targetEl.classList.contains('matched')) return;

            const sourceWord = sourceEl.id.replace('word-', '');
            const targetWord = targetEl.dataset.match;

            if (sourceWord === targetWord) {
                sourceEl.classList.add('matched');
                targetEl.classList.add('matched');
                sourceEl.draggable = false;
                sourceEl.removeAttribute('tabindex');
                
                updateScore();
                checkWinCondition();
            } else {
                sourceEl.style.animation = "shake 0.3s";
                setTimeout(() => sourceEl.style.animation = "", 300);
            }
        }

        function updateScore() {
            if (currentPlayer === 1) {
                scores.player1 += 10;
                document.getElementById('p1-score').textContent = scores.player1;
            } else {
                scores.player2 += 10;
                document.getElementById('p2-score').textContent = scores.player2;
            }
        }

        function startTimer() {
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                if (currentPlayer === 1) {
                    timers.player1--;
                    document.getElementById('p1-timer').textContent = timers.player1;
                    if (timers.player1 <= 0) handleTurnEnd();
                } else {
                    timers.player2--;
                    document.getElementById('p2-timer').textContent = timers.player2;
                    if (timers.player2 <= 0) handleTurnEnd();
                }
            }, 1000);
        }

        function checkWinCondition() {
            const remainingToMatch = draggableContainer.querySelectorAll('.draggable:not(.matched)');
            if (remainingToMatch.length === 0) {
                handleTurnEnd();
            }
        }

        function handleTurnEnd() {
            clearInterval(timerInterval);
            
            if (gameMode === 'double' && currentPlayer === 1) {
                currentPlayer = 2;
                alert("Player 1 turn complete! Pass the device to Player 2.");
                initializeRound();
            } else {
                showGameOver();
            }
        }

        function showGameOver() {
            gameBoard.classList.add('hidden');
            gameOverScreen.classList.remove('hidden');
            
            let resultsHTML = ``;
            if(gameMode === 'single') {
                resultsHTML = `<h3>Final Score: ${scores.player1}</h3><p>Time Remaining: ${timers.player1}s</p>`;
            } else {
                resultsHTML = `
                    <h3>Player 1 Score: ${scores.player1} (${timers.player1}s left)</h3>
                    <h3>Player 2 Score: ${scores.player2} (${timers.player2}s left)</h3>
                    <h2>🏆 ${scores.player1 > scores.player2 ? 'Player 1 Wins!' : scores.player2 > scores.player1 ? 'Player 2 Wins!' : "It's a Tie!"}</h2>
                `;
            }
            document.getElementById('final-results').innerHTML = resultsHTML;
        }

        function resetGame() {
            currentPlayer = 1;
            scores = { player1: 0, player2: 0 };
            timers = { player1: 30, player2: 30 };
            document.getElementById('p1-score').textContent = 0;
            document.getElementById('p2-score').textContent = 0;
            document.getElementById('p1-timer').textContent = 30;
            document.getElementById('p2-timer').textContent = 30;
            
            gameOverScreen.classList.add('hidden');
            modeSelection.classList.remove('hidden');
        }
    </script>
</body>
</html>
